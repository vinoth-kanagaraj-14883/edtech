# EXAMPLE — DO NOT COMMIT WITH REAL VALUES
# Copy this file to apm-device-key-secret.yaml, fill in your device key,
# and apply it to the cluster. The actual secret file is excluded by .gitignore.
#
# To create the secret from command line (recommended):
#   kubectl create secret generic site24x7-device-key \
#     --from-literal=device-key=YOUR_ACTUAL_KEY \
#     --namespace=site24x7-monitoring
#
# Or using this manifest (replace REPLACE_WITH_YOUR_DEVICE_KEY first):
apiVersion: v1
kind: Secret
metadata:
  name: site24x7-device-key
  namespace: site24x7-monitoring
  labels:
    app.kubernetes.io/managed-by: site24x7
type: Opaque
stringData:
  device-key: "REPLACE_WITH_YOUR_DEVICE_KEY"
