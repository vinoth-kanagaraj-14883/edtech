# EXAMPLE — DO NOT COMMIT WITH REAL VALUES
# This file shows the structure of the Secret needed for the Site24x7 server agent.
# The actual secret is created via CLI (see below) and is excluded by .gitignore.
#
# Create the secret using kubectl (recommended approach):
#   kubectl create secret generic site24x7-device-key \
#     --from-literal=device-key=YOUR_ACTUAL_DEVICE_KEY \
#     --namespace=site24x7-monitoring
#
# Or via this manifest (substitute the placeholder before applying):
apiVersion: v1
kind: Secret
metadata:
  name: site24x7-device-key
  namespace: site24x7-monitoring
  labels:
    app: site24x7-server-agent
    app.kubernetes.io/managed-by: site24x7
type: Opaque
stringData:
  device-key: "REPLACE_WITH_YOUR_DEVICE_KEY"
