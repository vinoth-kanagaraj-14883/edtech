# Site24x7 Go APM Environment Variables
# Generated by Ansible — source this file in the Go service systemd unit.
# Add to unit file: EnvironmentFile={{ site24x7_install_dir }}/go-apm.env

# Site24x7 device key (used as OTLP header)
SITE24X7_APM_KEY={{ site24x7_device_key }}

# Service identifier in Site24x7 portal
SITE24X7_SERVICE_NAME={{ site24x7_service_name }}

# Site24x7 APM endpoint
SITE24X7_APM_ENDPOINT={{ site24x7_apm_endpoint }}

# OTel-compatible endpoint — redirect existing OTel exporter to Site24x7
# The Go services already use OTel SDK; this env var alone activates Site24x7 APM.
SITE24X7_OTLP_ENDPOINT={{ site24x7_otlp_endpoint }}

# Log level
SITE24X7_LOG_LEVEL={{ site24x7_log_level }}
