# Site24x7 Linux Agent Configuration
# Generated by Ansible — do not edit manually.

[agent]
key={{ site24x7_device_key }}
poll_interval=60
enable_process=true

[proxy]
{% if site24x7_proxy_host != '' %}
proxy_server={{ site24x7_proxy_host }}
proxy_port={{ site24x7_proxy_port }}
{% if site24x7_proxy_user != '' %}
proxy_user={{ site24x7_proxy_user }}
proxy_password={{ site24x7_proxy_password }}
{% endif %}
{% endif %}

[logging]
log_level={{ site24x7_log_level | default('info') }}
