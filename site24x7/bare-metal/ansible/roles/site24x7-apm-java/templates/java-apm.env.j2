# Site24x7 Java APM Environment Variables
# Generated by Ansible — source this in the Java service systemd unit.
# Add to unit file: EnvironmentFile={{ site24x7_install_dir }}/java-apm.env

# Attach the Site24x7 Java APM agent at JVM startup
JAVA_TOOL_OPTIONS=-javaagent:{{ site24x7_install_dir }}/apm-agent.jar

# Site24x7 APM configuration
SITE24X7_APM_KEY={{ site24x7_device_key }}
SITE24X7_APM_APP_NAME={{ site24x7_service_name }}
SITE24X7_APM_ENDPOINT={{ site24x7_apm_endpoint }}
SITE24X7_LOG_LEVEL={{ site24x7_log_level }}
