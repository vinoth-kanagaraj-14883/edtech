global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: node
    static_configs:
{% for host in groups['edtech'] %}
      - targets: ['{{ hostvars[host].ansible_host | default(host) }}:9100']
        labels:
          instance: '{{ host }}'
{% endfor %}

  - job_name: api-gateway
    static_configs:
      - targets: ['{{ api_gateway_host }}:8080']
  - job_name: user-service
    static_configs:
      - targets: ['{{ user_service_host }}:8001']
  - job_name: course-service
    static_configs:
      - targets: ['{{ course_service_host }}:8002']
  - job_name: content-service
    static_configs:
      - targets: ['{{ content_service_host }}:8003']
  - job_name: quiz-service
    static_configs:
      - targets: ['{{ quiz_service_host }}:8004']
  - job_name: notification-service
    static_configs:
      - targets: ['{{ notification_service_host }}:8005']

  - job_name: mysql-exporter
    static_configs:
      - targets: ['{{ mysql_host }}:9104']

  - job_name: postgres-exporter
    static_configs:
      - targets: ['{{ postgresql_host }}:9187']

  - job_name: redis-exporter
    static_configs:
      - targets: ['{{ redis_host }}:9121']
